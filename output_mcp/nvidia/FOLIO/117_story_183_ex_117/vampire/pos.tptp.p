fof(distinct_michael_peter, axiom, michael != peter).\nfof(distinct_michael_windy, axiom, michael != windy).\nfof(distinct_peter_windy, axiom, peter != windy).\nfof(michael_man, axiom, man(michael)).\nfof(peter_man, axiom, man(peter)).\nfof(michael_taller_peter, axiom, taller(michael, peter)).\nfof(michael_taller_windy, axiom, taller(michael, windy)).\nfof(taller_trans, axiom, ! [X,Y,Z] : ((taller(X,Y) & taller(Y,Z)) => taller(X,Z))).\nfof(block_axiom, axiom, ! [X,Y] : ((man(X) & man(Y) & taller(X,Y)) => can_block(X,Y))).\nfof(michael_block_when_not_jump, axiom, ! [X] : (~jump(X) => can_block(michael,X))).\nfof(michael_no_block_windy, axiom, ~can_block(michael, windy)).\nfof(great_shooter_axiom, axiom, ! [X] : ((shooter(X) & jump(X)) => great_shooter(X))).\nfof(conclusion, conjecture, can_block(peter, windy)).