fof(ax1, axiom, ! [X] : ((animal(X) & barks(X)) => ~likes(jane, X))). fof(ax2, axiom, ! [X] : (dog(X) => (animal(X) & barks(X)))). fof(ax3, axiom, ! [X] : ((animal(X) & jumps(X)) => likes(jane, X))). fof(ax4, axiom, ! [X] : ((animal(X) & has_legs(X)) => jumps(X))). fof(ax5, axiom, ! [X] : ((animal(X) & terricolous(X)) => has_legs(X))). fof(ax6, axiom, animal(kiki)). fof(ax7, axiom, ( ~jumps(kiki) & ~has_legs(kiki) ) => ( terricolous(kiki) | has_legs(kiki) )). fof(goal, conjecture, (barks(kiki) | dog(kiki))).