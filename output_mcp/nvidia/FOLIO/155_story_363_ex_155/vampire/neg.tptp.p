% Axioms\nfof(ax1, axiom, ! [X] : (hydrocarbon(X) => organic(X))).\nfof(ax2, axiom, ! [X] : (alkane(X) => hydrocarbon(X))).\nfof(ax3, axiom, ! [X] : (organic(X) => chemical(X))).\nfof(ax4, axiom, ! [X] : (organic(X) => contains_carbon(X))).\nfof(ax5, axiom, ! [X] : (chemical(X) => ~one_element(X))).\nfof(ax6, axiom, (chemical(mixture) <=> one_element(mixture))).\n\n% Negated Conjecture\nfof(neg_goal, conjecture, (one_element(mixture) | contains_carbon(mixture)) & (chemical(mixture) | alkane(mixture))).